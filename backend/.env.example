# Copy this file to ".env" and fill in your own values.
# The real .env is git-ignored so passwords never end up on GitHub.

# Where the PostgreSQL database lives.
# Local Mac (Homebrew) needs no password:
DATABASE_URL=postgres://localhost:5432/crk_team_builder
# Windows install would look like:
# DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/crk_team_builder

# Port the API listens on
PORT=4000

# Set to true ONLY for cloud databases (Neon/Render) that require
# encrypted connections. Leave unset for the local database.
# DATABASE_SSL=true

# Secret used to sign login tokens. Any long random string.
# Locally this can stay as-is; in production set a real secret.
JWT_SECRET=local-dev-secret
