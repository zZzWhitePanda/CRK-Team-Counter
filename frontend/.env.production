# Vite reads this file automatically when building for production
# (npm run build / Vercel). It tells the frontend where the live
# backend API is. This is a PUBLIC address, not a secret, so it's
# safe to commit. In development this file is ignored and requests
# go through the Vite proxy to localhost:4000 instead.
VITE_API_URL=https://crk-team-builder-api.onrender.com
